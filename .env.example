# ============================================================
# SQAC API Gateway — single .env for the whole deployment.
# The gateway runs in ONE process, so all backends read these.
# On Koyeb, set these as the service's Environment Variables.
# ============================================================

# Port the gateway listens on (Koyeb injects PORT automatically — usually 8080)
PORT=8080

# Optional: set to the public gateway URL to enable keep-alive self-ping
# KEEPALIVE_URL=https://your-app.koyeb.app

# ---------- Databases ----------
# Use separate URIs if the two backends use different databases.
# If both share one cluster/db, you can instead just set MONGO_URI.
PORTAL_MONGO_URI=
WEBSITE_MONGO_URI=
# MONGO_URI=   # fallback used by both if the specific ones are unset

# ---------- Portal backend ----------
FRONTEND_URL=https://portal-frontend.example.com,https://website-frontend.example.com
JWT_SECRET=
GROQ_API_KEY=
REDIS_URI=

# Portal Cloudinary
CLOUDINARY_CLOUD=
CLOUDINARY_API=
CLOUDINARY_SECRET=

# Portal Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=

# Portal email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Portal Google Drive (service account JSON as a single-line string)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---------- Website backend ----------
# Website Cloudinary (note: different var names than the portal's)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
