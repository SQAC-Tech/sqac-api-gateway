# SQAC Website backend — environment variables
# NOTE: In the gateway deployment these live in the ROOT .env (single process).
# This file documents what the website backend itself needs.

# MongoDB connection (gateway passes WEBSITE_MONGO_URI; falls back to MONGO_URI)
WEBSITE_MONGO_URI=
# MONGO_URI=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local standalone run only (ignored when run via the gateway)
PORT=5000
